<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="EtwSuite.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:EtwSuite"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:media="using:Microsoft.UI.Xaml.Media"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d"
    Title="EtwSuite">

    <Window.SystemBackdrop>
        <media:MicaBackdrop />
    </Window.SystemBackdrop>

    <controls:Grid
        x:Name="Root"
        Padding="20"
        Loaded="Root_Loaded"
        RowSpacing="12">
        <controls:Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </controls:Grid.RowDefinitions>

        <controls:Grid>
            <controls:StackPanel Spacing="4">
                <controls:TextBlock
                    FontSize="22"
                    FontWeight="SemiBold"
                    Text="ETW Providers" />
                <controls:TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{Binding ProviderCountText}" />
            </controls:StackPanel>
        </controls:Grid>

        <controls:Grid
            Grid.Row="1"
            ColumnSpacing="16">
            <controls:Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
            </controls:Grid.ColumnDefinitions>
            <controls:Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </controls:Grid.RowDefinitions>

            <controls:StackPanel
                Orientation="Horizontal"
                Spacing="12"
                Margin="0,0,0,8">
                <controls:TextBox
                    Width="300"
                    Header="Search"
                    PlaceholderText="Provider name or GUID"
                    TextChanged="SearchTextBox_TextChanged" />
                <controls:CheckBox
                    VerticalAlignment="Bottom"
                    Content="Show missing or providers with no events"
                    IsChecked="{Binding ShowMissingProviders, Mode=TwoWay}" />
            </controls:StackPanel>

            <controls:ListView
                Grid.Row="2"
                ItemsSource="{Binding Providers}"
                SelectedItem="{Binding SelectedProvider, Mode=TwoWay}"
                SelectionChanged="ProvidersListView_SelectionChanged"
                SelectionMode="Single">
                <controls:ListView.ItemTemplate>
                    <DataTemplate>
                        <controls:StackPanel Padding="4" Spacing="3">
                            <controls:TextBlock
                                FontWeight="SemiBold"
                                Text="{Binding Name}"
                                TextTrimming="CharacterEllipsis" />
                            <controls:TextBlock
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="{Binding Id}" />
                        </controls:StackPanel>
                    </DataTemplate>
                </controls:ListView.ItemTemplate>
            </controls:ListView>

            <controls:Grid
                Grid.Column="1"
                Grid.RowSpan="3"
                Padding="4"
                DataContext="{Binding SelectedProviderDetails}"
                RowSpacing="10">
                <controls:Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </controls:Grid.RowDefinitions>

                <controls:TextBlock
                    FontSize="20"
                    FontWeight="SemiBold"
                    IsTextSelectionEnabled="True"
                    Text="{Binding Name}"
                    TextWrapping="Wrap" />

                <controls:StackPanel
                    Grid.Row="1"
                    Spacing="4">
                    <controls:TextBlock
                        FontWeight="SemiBold"
                        Text="Provider GUID" />
                    <controls:TextBox
                        FontFamily="Consolas"
                        IsReadOnly="True"
                        Text="{Binding IdText}"
                        TextWrapping="Wrap" />
                </controls:StackPanel>

                <controls:StackPanel
                    Grid.Row="2"
                    Spacing="4">
                    <controls:TextBlock
                        FontWeight="SemiBold"
                        Text="Schema source" />
                    <controls:TextBox
                        IsReadOnly="True"
                        Text="{Binding SchemaSource}" />
                </controls:StackPanel>

                <controls:StackPanel
                    Grid.Row="3"
                    Spacing="4">
                    <controls:TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{Binding SchemaCountText}"
                        TextWrapping="Wrap" />
                    <controls:TextBlock
                        Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                        Text="{Binding SchemaStatus}"
                        TextWrapping="Wrap" />
                </controls:StackPanel>

                <controls:Grid
                    Grid.Row="4"
                    RowSpacing="8">
                    <controls:Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="2*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </controls:Grid.RowDefinitions>

                    <controls:TextBox
                        Header="Search schema"
                        PlaceholderText="Event, task, id, opcode, level, parameter, or type"
                        TextChanged="SchemaSearchTextBox_TextChanged" />

                    <controls:ListView
                        x:Name="SchemaList"
                        Grid.Row="1"
                        ItemsSource="{Binding SchemaItems}"
                        SelectedItem="{Binding SelectedSchemaItem, Mode=TwoWay}"
                        SelectionMode="Single">
                        <controls:ListView.ItemContainerStyle>
                            <Style TargetType="controls:ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </controls:ListView.ItemContainerStyle>
                        <controls:ListView.Header>
                            <controls:Grid
                                Padding="12,8,12,8"
                                ColumnSpacing="12"
                                HorizontalAlignment="Stretch">
                                <controls:Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </controls:Grid.ColumnDefinitions>
                                <controls:TextBlock
                                    FontWeight="SemiBold"
                                    Text="Name" />
                                <controls:TextBlock
                                    Grid.Column="1"
                                    FontWeight="SemiBold"
                                    Text="ID" />
                                <controls:TextBlock
                                    Grid.Column="2"
                                    FontWeight="SemiBold"
                                    Text="Version" />
                                <controls:TextBlock
                                    Grid.Column="3"
                                    FontWeight="SemiBold"
                                    Text="Opcode" />
                                <controls:TextBlock
                                    Grid.Column="4"
                                    FontWeight="SemiBold"
                                    Text="Level" />
                            </controls:Grid>
                        </controls:ListView.Header>
                        <controls:ListView.ItemTemplate>
                            <DataTemplate>
                                <controls:Grid
                                    Padding="12,6,12,6"
                                    ColumnSpacing="12"
                                    HorizontalAlignment="Stretch">
                                    <controls:Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </controls:Grid.ColumnDefinitions>

                                    <controls:TextBlock
                                        FontWeight="SemiBold"
                                        IsTextSelectionEnabled="True"
                                        Text="{Binding Name}"
                                        TextTrimming="CharacterEllipsis" />
                                    <controls:TextBlock
                                        Grid.Column="1"
                                        IsTextSelectionEnabled="True"
                                        Text="{Binding Id}" />
                                    <controls:TextBlock
                                        Grid.Column="2"
                                        IsTextSelectionEnabled="True"
                                        Text="{Binding Version}" />
                                    <controls:TextBlock
                                        Grid.Column="3"
                                        IsTextSelectionEnabled="True"
                                        Text="{Binding Opcode}"
                                        TextTrimming="CharacterEllipsis" />
                                    <controls:TextBlock
                                        Grid.Column="4"
                                        IsTextSelectionEnabled="True"
                                        Text="{Binding Level}"
                                        TextTrimming="CharacterEllipsis" />
                                </controls:Grid>
                            </DataTemplate>
                        </controls:ListView.ItemTemplate>
                    </controls:ListView>

                    <controls:Grid
                        Grid.Row="2"
                        Padding="12,8,12,4"
                        ColumnSpacing="12">
                        <controls:Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="*" />
                        </controls:Grid.ColumnDefinitions>
                        <controls:TextBlock
                            FontWeight="SemiBold"
                            Text="Name" />
                        <controls:TextBlock
                            Grid.Column="1"
                            FontWeight="SemiBold"
                            Text="Type" />
                    </controls:Grid>

                    <controls:ListView
                        x:Name="ParameterList"
                        Grid.Row="3"
                        ItemsSource="{Binding SelectedSchemaItem.Parameters}"
                        SelectionMode="None">
                        <controls:ListView.ItemContainerStyle>
                            <Style TargetType="controls:ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </controls:ListView.ItemContainerStyle>
                        <controls:ListView.ItemTemplate>
                            <DataTemplate>
                                <controls:Grid
                                    Padding="12,4,12,4"
                                    ColumnSpacing="12"
                                    HorizontalAlignment="Stretch">
                                    <controls:Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="*" />
                                    </controls:Grid.ColumnDefinitions>
                                    <controls:TextBlock
                                        IsTextSelectionEnabled="True"
                                        Text="{Binding Name}"
                                        TextTrimming="CharacterEllipsis" />
                                    <controls:TextBlock
                                        Grid.Column="1"
                                        IsTextSelectionEnabled="True"
                                        Text="{Binding Type}" />
                                </controls:Grid>
                            </DataTemplate>
                        </controls:ListView.ItemTemplate>
                    </controls:ListView>
                </controls:Grid>
            </controls:Grid>
        </controls:Grid>
    </controls:Grid>
</Window>
