<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="EtwSuite.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d"
    Title="EtwSuite">

    <controls:NavigationView
        x:Name="Root"
        IsSettingsVisible="False"
        Loaded="Root_Loaded"
        SelectionChanged="Root_SelectionChanged">
        <controls:NavigationView.PaneHeader>
            <controls:Grid
                Width="296"
                Height="64"
                Padding="12,6">
                <Image
                    Width="720"
                    Height="140"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    AutomationProperties.Name="EtwSuite"
                    Source="Assets/EtwSuite_Logo.png"
                    Stretch="Uniform" />
            </controls:Grid>
        </controls:NavigationView.PaneHeader>

        <controls:NavigationView.MenuItems>
            <controls:NavigationViewItem
                x:Name="ListProvidersNavigationItem"
                Content="List Providers"
                IsSelected="True"
                Tag="ListProviders">
                <controls:NavigationViewItem.Icon>
                    <controls:SymbolIcon Symbol="List" />
                </controls:NavigationViewItem.Icon>
            </controls:NavigationViewItem>
            <controls:NavigationViewItem
                x:Name="ConsumeProviderNavigationItem"
                Content="Consume Provider"
                Tag="ConsumeProvider">
                <controls:NavigationViewItem.Icon>
                    <controls:FontIcon Glyph="&#xE9D9;" />
                </controls:NavigationViewItem.Icon>
            </controls:NavigationViewItem>
            <controls:NavigationViewItem
                x:Name="OpenRecordingNavigationItem"
                Content="Open Recording"
                Tag="OpenRecording">
                <controls:NavigationViewItem.Icon>
                    <controls:FontIcon Glyph="&#xE8E5;" />
                </controls:NavigationViewItem.Icon>
            </controls:NavigationViewItem>
            <controls:NavigationViewItem
                x:Name="SavedSessionsNavigationItem"
                Content="Saved Sessions"
                Tag="SavedSessions">
                <controls:NavigationViewItem.Icon>
                    <controls:FontIcon Glyph="&#xE8D3;" />
                </controls:NavigationViewItem.Icon>
            </controls:NavigationViewItem>
            <controls:NavigationViewItem
                x:Name="HelpNavigationItem"
                Content="Help"
                Tag="Help">
                <controls:NavigationViewItem.Icon>
                    <controls:SymbolIcon Symbol="Help" />
                </controls:NavigationViewItem.Icon>
            </controls:NavigationViewItem>
        </controls:NavigationView.MenuItems>

        <controls:Grid Padding="20">
            <controls:Grid
                x:Name="ListProvidersView"
                RowSpacing="12"
                Visibility="Visible">
                <controls:Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </controls:Grid.RowDefinitions>

                <controls:StackPanel Spacing="4">
                    <controls:TextBlock
                        FontSize="22"
                        FontWeight="SemiBold"
                        Text="List Providers" />
                    <controls:TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{Binding ProviderCountText}" />
                    <controls:TextBlock
                        Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                        Text="{Binding ErrorMessage}"
                        TextWrapping="Wrap" />
                </controls:StackPanel>

                <controls:Grid
                    Grid.Row="1"
                    ColumnSpacing="16">
                    <controls:Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="3*" />
                    </controls:Grid.ColumnDefinitions>
                    <controls:Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </controls:Grid.RowDefinitions>

                    <controls:StackPanel
                        Orientation="Horizontal"
                        Spacing="12"
                        Margin="0,0,0,8">
                        <controls:TextBox
                            x:Name="ProviderSearchTextBox"
                            MinWidth="260"
                            Width="320"
                            Header="Search"
                            PlaceholderText="Provider name or GUID"
                            KeyDown="ProviderSearchTextBox_KeyDown"
                            TextChanged="SearchTextBox_TextChanged" />
                        <controls:CheckBox
                            VerticalAlignment="Bottom"
                            Content="Show missing or providers with no events"
                            IsChecked="{Binding ShowMissingProviders, Mode=TwoWay}" />
                    </controls:StackPanel>

                    <controls:ListView
                        Grid.Row="2"
                        ItemsSource="{Binding Providers}"
                        SelectedItem="{Binding SelectedProvider, Mode=TwoWay}"
                        SelectionChanged="ProvidersListView_SelectionChanged"
                        SelectionMode="Single">
                        <controls:ListView.ItemTemplate>
                            <DataTemplate>
                                <controls:StackPanel Padding="4" Spacing="3">
                                    <controls:StackPanel.ContextFlyout>
                                        <controls:MenuFlyout>
                                            <controls:MenuFlyoutItem
                                                Click="ConsumeProviderFromListFlyoutItem_Click"
                                                Tag="{Binding}"
                                                Text="Consume this provider" />
                                        </controls:MenuFlyout>
                                    </controls:StackPanel.ContextFlyout>
                                    <controls:TextBlock
                                        FontWeight="SemiBold"
                                        Text="{Binding Name}"
                                        TextTrimming="CharacterEllipsis" />
                                    <controls:TextBlock
                                        FontSize="12"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{Binding Id}" />
                                </controls:StackPanel>
                            </DataTemplate>
                        </controls:ListView.ItemTemplate>
                    </controls:ListView>

                    <controls:Grid
                        Grid.Column="1"
                        Grid.RowSpan="3"
                        Padding="4"
                        DataContext="{Binding SelectedProviderDetails}"
                        RowSpacing="10">
                        <controls:Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </controls:Grid.RowDefinitions>

                        <controls:TextBlock
                            FontSize="20"
                            FontWeight="SemiBold"
                            IsTextSelectionEnabled="True"
                            Text="{Binding Name}"
                            TextWrapping="Wrap" />

                        <controls:StackPanel Grid.Row="1" Spacing="4">
                            <controls:TextBlock FontWeight="SemiBold" Text="Provider GUID" />
                            <controls:TextBox
                                FontFamily="Consolas"
                                IsReadOnly="True"
                                Text="{Binding IdText}"
                                TextWrapping="Wrap" />
                        </controls:StackPanel>

                        <controls:StackPanel Grid.Row="2" Spacing="4">
                            <controls:TextBlock FontWeight="SemiBold" Text="Schema source" />
                            <controls:TextBox IsReadOnly="True" Text="{Binding SchemaSource}" />
                        </controls:StackPanel>

                        <controls:StackPanel Grid.Row="3" Spacing="4">
                            <controls:TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="{Binding SchemaCountText}"
                                TextWrapping="Wrap" />
                            <controls:TextBlock
                                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                Text="{Binding SchemaStatus}"
                                TextWrapping="Wrap" />
                        </controls:StackPanel>

                        <controls:Grid Grid.Row="4" RowSpacing="8">
                            <controls:Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </controls:Grid.RowDefinitions>

                            <controls:TextBox
                                x:Name="SchemaSearchTextBox"
                                Header="Search schema"
                                PlaceholderText="Event, task, id, opcode, level, parameter, or type"
                                KeyDown="SchemaSearchTextBox_KeyDown"
                                TextChanged="SchemaSearchTextBox_TextChanged" />

                            <controls:Border
                                Grid.Row="1"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="4">
                                <controls:ListView
                                    ItemsSource="{Binding SchemaItems}"
                                    SelectionMode="None">
                                    <controls:ListView.ItemContainerStyle>
                                        <Style TargetType="controls:ListViewItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            <Setter Property="Padding" Value="0" />
                                        </Style>
                                    </controls:ListView.ItemContainerStyle>
                                    <controls:ListView.Header>
                                        <controls:Grid
                                            Padding="0,8,12,8"
                                            ColumnSpacing="12"
                                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                            <controls:Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </controls:Grid.ColumnDefinitions>
                                            <controls:TextBlock FontWeight="SemiBold" Text="Name" />
                                            <controls:TextBlock Grid.Column="1" FontWeight="SemiBold" Text="ID" />
                                            <controls:TextBlock Grid.Column="2" FontWeight="SemiBold" Text="Version" />
                                            <controls:TextBlock Grid.Column="3" FontWeight="SemiBold" Text="Opcode" />
                                            <controls:TextBlock Grid.Column="4" FontWeight="SemiBold" Text="Level" />
                                        </controls:Grid>
                                    </controls:ListView.Header>
                                    <controls:ListView.ItemTemplate>
                                        <DataTemplate>
                                            <controls:Expander
                                                HorizontalContentAlignment="Stretch"
                                                HorizontalAlignment="Stretch">
                                                <controls:Expander.Header>
                                                    <controls:Grid
                                                        MinHeight="36"
                                                        Padding="48,6,12,6"
                                                        ColumnSpacing="12"
                                                        HorizontalAlignment="Stretch">
                                                        <controls:Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="2*" />
                                                            <ColumnDefinition Width="80" />
                                                            <ColumnDefinition Width="80" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="*" />
                                                        </controls:Grid.ColumnDefinitions>
                                                        <controls:TextBlock FontWeight="SemiBold" IsTextSelectionEnabled="True" Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                                        <controls:TextBlock Grid.Column="1" IsTextSelectionEnabled="True" Text="{Binding Id}" />
                                                        <controls:TextBlock Grid.Column="2" IsTextSelectionEnabled="True" Text="{Binding Version}" />
                                                        <controls:TextBlock Grid.Column="3" IsTextSelectionEnabled="True" Text="{Binding Opcode}" TextTrimming="CharacterEllipsis" />
                                                        <controls:TextBlock Grid.Column="4" IsTextSelectionEnabled="True" Text="{Binding Level}" TextTrimming="CharacterEllipsis" />
                                                    </controls:Grid>
                                                </controls:Expander.Header>

                                                <controls:Grid
                                                    HorizontalAlignment="Stretch"
                                                    Padding="48,0,12,12"
                                                    RowSpacing="6">
                                                    <controls:Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </controls:Grid.RowDefinitions>
                                                    <controls:TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding ParameterCountText}" />
                                                    <controls:Grid Grid.Row="1" Padding="0,6,0,4" ColumnSpacing="12">
                                                        <controls:Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </controls:Grid.ColumnDefinitions>
                                                        <controls:TextBlock FontWeight="SemiBold" Text="Name" />
                                                        <controls:TextBlock Grid.Column="1" FontWeight="SemiBold" HorizontalAlignment="Right" Text="Type" />
                                                    </controls:Grid>
                                                    <controls:ItemsControl Grid.Row="2" ItemsSource="{Binding Parameters}">
                                                        <controls:ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <controls:Grid HorizontalAlignment="Stretch" Padding="0,3,0,3" ColumnSpacing="12">
                                                                    <controls:Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </controls:Grid.ColumnDefinitions>
                                                                    <controls:TextBlock IsTextSelectionEnabled="True" Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                                                    <controls:TextBlock Grid.Column="1" HorizontalAlignment="Right" IsTextSelectionEnabled="True" Text="{Binding Type}" TextTrimming="CharacterEllipsis" />
                                                                </controls:Grid>
                                                            </DataTemplate>
                                                        </controls:ItemsControl.ItemTemplate>
                                                    </controls:ItemsControl>
                                                </controls:Grid>
                                            </controls:Expander>
                                        </DataTemplate>
                                    </controls:ListView.ItemTemplate>
                                </controls:ListView>
                            </controls:Border>
                        </controls:Grid>
                    </controls:Grid>
                </controls:Grid>
            </controls:Grid>

            <controls:Grid
                x:Name="ConsumeProviderView"
                RowSpacing="12"
                Visibility="Collapsed">
                <controls:Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </controls:Grid.RowDefinitions>

                <controls:StackPanel Spacing="4">
                    <controls:TextBlock
                        FontSize="22"
                        FontWeight="SemiBold"
                        Text="Consume Provider" />
                    <controls:TextBlock
                        FontWeight="SemiBold"
                        Text="Selected provider" />
                    <controls:TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{Binding SelectedProviderText}"
                        TextWrapping="Wrap" />
                </controls:StackPanel>

                <controls:Grid
                    Grid.Row="1"
                    ColumnSpacing="12"
                    RowSpacing="8">
                    <controls:Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </controls:Grid.ColumnDefinitions>
                    <controls:Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </controls:Grid.RowDefinitions>

                    <controls:TextBox
                        x:Name="ConsumeProviderSearchTextBox"
                        Header="Provider search"
                        PlaceholderText="Provider name or GUID"
                        KeyDown="ConsumeSearchTextBox_KeyDown"
                        TextChanged="ConsumeSearchTextBox_TextChanged" />

                    <controls:Button
                        Grid.Column="1"
                        VerticalAlignment="Bottom"
                        Click="StartStopConsumingButton_Click"
                        Content="{Binding StartStopText}"
                        IsEnabled="{Binding CanStartOrStop}" />

                    <controls:ComboBox
                        Grid.Column="2"
                        VerticalAlignment="Bottom"
                        Header="Export to"
                        ItemsSource="{Binding ExportFormats}"
                        SelectedItem="{Binding SelectedExportFormat, Mode=TwoWay}" />

                    <controls:Button
                        Grid.Column="3"
                        VerticalAlignment="Bottom"
                        Click="ExportEventsButton_Click"
                        Content="Export"
                        IsEnabled="{Binding CanExport}" />

                    <controls:CheckBox
                        Grid.Column="4"
                        VerticalAlignment="Bottom"
                        Content="Record ETL"
                        IsChecked="{Binding IsEtlRecordingEnabled, Mode=TwoWay}" />

                    <controls:Button
                        Grid.Column="5"
                        VerticalAlignment="Bottom"
                        Click="OpenLastRecordingButton_Click"
                        Content="Open recorded"
                        IsEnabled="{Binding CanOpenLastRecording}" />

                    <controls:StackPanel
                        Grid.Column="6"
                        VerticalAlignment="Bottom"
                        Spacing="2">
                        <controls:TextBlock Text="{Binding TotalEventCountText}" />
                        <controls:TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{Binding DroppedEventsText}" />
                        <controls:TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{Binding EtlRecordingText}"
                            TextTrimming="CharacterEllipsis" />
                    </controls:StackPanel>

                    <controls:ListView
                        x:Name="ConsumeProviderMatchesListView"
                        Grid.Row="1"
                        MaxHeight="160"
                        Margin="0,8,0,0"
                        ItemsSource="{Binding Providers}"
                        SelectedItem="{Binding SelectedProvider, Mode=TwoWay}"
                        SelectionChanged="ConsumeProvidersListView_SelectionChanged"
                        SelectionMode="Single"
                        Visibility="Collapsed">
                        <controls:ListView.ItemTemplate>
                            <DataTemplate>
                                <controls:Grid Padding="4,3" RowSpacing="2">
                                    <controls:Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </controls:Grid.RowDefinitions>
                                    <controls:TextBlock
                                        FontWeight="SemiBold"
                                        Text="{Binding Name}"
                                        TextTrimming="CharacterEllipsis" />
                                    <controls:TextBlock
                                        Grid.Row="1"
                                        FontSize="12"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{Binding Id}"
                                        TextTrimming="CharacterEllipsis" />
                                </controls:Grid>
                            </DataTemplate>
                        </controls:ListView.ItemTemplate>
                    </controls:ListView>

                    <controls:TextBlock
                        Grid.Row="2"
                        Grid.ColumnSpan="7"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{Binding StatusMessage}"
                        TextWrapping="Wrap" />
                </controls:Grid>

                <controls:Grid
                    Grid.Row="2"
                    ColumnSpacing="12">
                    <controls:Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </controls:Grid.ColumnDefinitions>

                    <controls:ComboBox
                        MinWidth="92"
                        Header="Mode"
                        ItemsSource="{Binding EventFilterModes}"
                        SelectedItem="{Binding SelectedEventFilterMode, Mode=TwoWay}" />
                    <controls:TextBox
                        x:Name="EventFilterTextBox"
                        Grid.Column="1"
                        Header="Event filter"
                        PlaceholderText="Basic text/wildcards or SQL WHERE expression"
                        TextChanged="EventFilterTextBox_TextChanged" />
                </controls:Grid>

                <controls:Grid
                    Grid.Row="3"
                    ColumnSpacing="8">
                    <controls:Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </controls:Grid.ColumnDefinitions>

                    <controls:TextBox
                        Width="120"
                        Header="Events per page"
                        Text="{Binding EventsPerPage, Mode=TwoWay}"
                        TextChanged="EventsPerPageTextBox_TextChanged" />
                    <controls:Button
                        Grid.Column="1"
                        VerticalAlignment="Bottom"
                        Click="PreviousEventsPageButton_Click"
                        Content="Previous"
                        IsEnabled="{Binding CanGoToPreviousPage}" />
                    <controls:Button
                        Grid.Column="2"
                        VerticalAlignment="Bottom"
                        Click="NextEventsPageButton_Click"
                        Content="Next"
                        IsEnabled="{Binding CanGoToNextPage}" />
                    <controls:StackPanel
                        Grid.Column="3"
                        VerticalAlignment="Bottom"
                        Orientation="Horizontal"
                        Spacing="12">
                        <controls:TextBlock Text="{Binding PageStatusText}" />
                        <controls:TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{Binding EventCountText}" />
                    </controls:StackPanel>
                </controls:Grid>

                <controls:Border
                    Grid.Row="4"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                    <controls:ListView
                        ItemsSource="{Binding Events}"
                        SelectionMode="None">
                        <controls:ListView.ItemContainerStyle>
                            <Style TargetType="controls:ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                            </Style>
                        </controls:ListView.ItemContainerStyle>
                        <controls:ListView.Header>
                            <controls:Grid
                                Padding="48,8,12,8"
                                ColumnSpacing="12"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                <controls:Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="420" />
                                    <ColumnDefinition Width="420" />
                                    <ColumnDefinition Width="64" />
                                    <ColumnDefinition Width="72" />
                                    <ColumnDefinition Width="72" />
                                    <ColumnDefinition Width="64" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="120" />
                                </controls:Grid.ColumnDefinitions>
                                <controls:TextBlock FontWeight="SemiBold" Text="Time" />
                                <controls:TextBlock Grid.Column="1" FontWeight="SemiBold" Text="Provider" />
                                <controls:TextBlock Grid.Column="2" FontWeight="SemiBold" Text="Event" />
                                <controls:TextBlock Grid.Column="3" FontWeight="SemiBold" Text="ID" />
                                <controls:TextBlock Grid.Column="4" FontWeight="SemiBold" Text="Version" />
                                <controls:TextBlock Grid.Column="5" FontWeight="SemiBold" Text="Opcode" />
                                <controls:TextBlock Grid.Column="6" FontWeight="SemiBold" Text="Level" />
                                <controls:TextBlock Grid.Column="7" FontWeight="SemiBold" Text="PID" />
                                <controls:TextBlock Grid.Column="8" FontWeight="SemiBold" Text="Process" />
                                <controls:TextBlock Grid.Column="9" FontWeight="SemiBold" Text="Parameters" />
                            </controls:Grid>
                        </controls:ListView.Header>
                        <controls:ListView.ItemTemplate>
                            <DataTemplate>
                                <controls:Expander
                                    HorizontalContentAlignment="Stretch"
                                    HorizontalAlignment="Stretch">
                                    <controls:Expander.Header>
                                        <controls:Grid
                                            MinHeight="36"
                                            Padding="33,6,12,6"
                                            ColumnSpacing="12"
                                            HorizontalAlignment="Stretch">
                                            <controls:Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="420" />
                                                <ColumnDefinition Width="420" />
                                                <ColumnDefinition Width="64" />
                                                <ColumnDefinition Width="72" />
                                                <ColumnDefinition Width="72" />
                                                <ColumnDefinition Width="64" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="120" />
                                            </controls:Grid.ColumnDefinitions>
                                            <controls:TextBlock IsTextSelectionEnabled="True" Text="{Binding Time}" />
                                            <controls:TextBlock Grid.Column="1" IsTextSelectionEnabled="True" Text="{Binding Provider}" TextTrimming="CharacterEllipsis" />
                                            <controls:TextBlock Grid.Column="2" FontWeight="SemiBold" IsTextSelectionEnabled="True" Text="{Binding Event}" TextTrimming="CharacterEllipsis" />
                                            <controls:TextBlock Grid.Column="3" IsTextSelectionEnabled="True" Text="{Binding Id}" />
                                            <controls:TextBlock Grid.Column="4" IsTextSelectionEnabled="True" Text="{Binding Version}" />
                                            <controls:TextBlock Grid.Column="5" IsTextSelectionEnabled="True" Text="{Binding Opcode}" />
                                            <controls:TextBlock Grid.Column="6" IsTextSelectionEnabled="True" Text="{Binding Level}" />
                                            <controls:TextBlock Grid.Column="7" IsTextSelectionEnabled="True" Text="{Binding ProcessId}" />
                                            <controls:TextBlock Grid.Column="8" IsTextSelectionEnabled="True" Text="{Binding ProcessName}" TextTrimming="CharacterEllipsis" />
                                            <controls:TextBlock Grid.Column="9" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding ParameterSummary}" />
                                        </controls:Grid>
                                    </controls:Expander.Header>

                                    <controls:Grid Padding="48,0,12,12" RowSpacing="6">
                                        <controls:Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </controls:Grid.RowDefinitions>
                                        <controls:Grid Padding="0,6,0,4" ColumnSpacing="12">
                                            <controls:Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="260" />
                                                <ColumnDefinition Width="*" />
                                            </controls:Grid.ColumnDefinitions>
                                            <controls:TextBlock FontWeight="SemiBold" Text="Name" />
                                            <controls:TextBlock Grid.Column="1" FontWeight="SemiBold" Text="Value" />
                                        </controls:Grid>
                                        <controls:ItemsControl Grid.Row="1" ItemsSource="{Binding Parameters}">
                                            <controls:ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <controls:Grid Padding="0,3,0,3" ColumnSpacing="12">
                                                        <controls:Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="260" />
                                                            <ColumnDefinition Width="*" />
                                                        </controls:Grid.ColumnDefinitions>
                                                        <controls:TextBlock IsTextSelectionEnabled="True" Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                                        <controls:TextBlock Grid.Column="1" IsTextSelectionEnabled="True" Text="{Binding Value}" TextTrimming="CharacterEllipsis" />
                                                    </controls:Grid>
                                                </DataTemplate>
                                            </controls:ItemsControl.ItemTemplate>
                                        </controls:ItemsControl>
                                    </controls:Grid>
                                </controls:Expander>
                            </DataTemplate>
                        </controls:ListView.ItemTemplate>
                    </controls:ListView>
                </controls:Border>
            </controls:Grid>

            <controls:Grid
                x:Name="OpenRecordingView"
                RowSpacing="12"
                Visibility="Collapsed">
                <controls:Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </controls:Grid.RowDefinitions>

                <controls:StackPanel Spacing="4">
                    <controls:TextBlock
                        FontSize="22"
                        FontWeight="SemiBold"
                        Text="Open Recording" />
                    <controls:TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{Binding EventCountText}" />
                    <controls:TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{Binding DroppedEventsText}" />
                </controls:StackPanel>

                <controls:Grid
                    Grid.Row="1"
                    ColumnSpacing="12">
                    <controls:Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </controls:Grid.ColumnDefinitions>

                    <controls:Button
                        VerticalAlignment="Bottom"
                        Click="OpenRecordingFileButton_Click"
                        Content="Open file"
                        IsEnabled="{Binding CanOpenFile}" />
                    <controls:StackPanel
                        Grid.Column="1"
                        Spacing="2">
                        <controls:TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{Binding SelectedFilePath}"
                            TextTrimming="CharacterEllipsis" />
                        <controls:TextBlock
                            Text="{Binding StatusMessage}"
                            TextWrapping="Wrap" />
                    </controls:StackPanel>
                </controls:Grid>

                <controls:Grid
                    Grid.Row="2"
                    ColumnSpacing="12">
                    <controls:Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </controls:Grid.ColumnDefinitions>

                    <controls:ComboBox
                        MinWidth="92"
                        Header="Mode"
                        ItemsSource="{Binding EventFilterModes}"
                        SelectedItem="{Binding SelectedEventFilterMode, Mode=TwoWay}" />
                    <controls:TextBox
                        x:Name="OpenRecordingEventFilterTextBox"
                        Grid.Column="1"
                        Header="Event filter"
                        PlaceholderText="Basic text/wildcards or SQL WHERE expression"
                        TextChanged="OpenRecordingEventFilterTextBox_TextChanged" />
                </controls:Grid>

                <controls:Grid
                    Grid.Row="3"
                    ColumnSpacing="8">
                    <controls:Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </controls:Grid.ColumnDefinitions>

                    <controls:TextBox
                        Width="120"
                        Header="Events per page"
                        Text="{Binding EventsPerPage, Mode=TwoWay}"
                        TextChanged="OpenRecordingEventsPerPageTextBox_TextChanged" />
                    <controls:Button
                        Grid.Column="1"
                        VerticalAlignment="Bottom"
                        Click="OpenRecordingPreviousEventsPageButton_Click"
                        Content="Previous"
                        IsEnabled="{Binding CanGoToPreviousPage}" />
                    <controls:Button
                        Grid.Column="2"
                        VerticalAlignment="Bottom"
                        Click="OpenRecordingNextEventsPageButton_Click"
                        Content="Next"
                        IsEnabled="{Binding CanGoToNextPage}" />
                    <controls:StackPanel
                        Grid.Column="3"
                        VerticalAlignment="Bottom"
                        Orientation="Horizontal"
                        Spacing="12">
                        <controls:TextBlock Text="{Binding PageStatusText}" />
                        <controls:TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{Binding EventCountText}" />
                    </controls:StackPanel>
                </controls:Grid>

                <controls:Border
                    Grid.Row="4"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                    <controls:ListView
                        ItemsSource="{Binding Events}"
                        SelectionMode="None">
                        <controls:ListView.ItemContainerStyle>
                            <Style TargetType="controls:ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                            </Style>
                        </controls:ListView.ItemContainerStyle>
                        <controls:ListView.Header>
                            <controls:Grid
                                Padding="48,8,12,8"
                                ColumnSpacing="12"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                <controls:Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="420" />
                                    <ColumnDefinition Width="420" />
                                    <ColumnDefinition Width="64" />
                                    <ColumnDefinition Width="72" />
                                    <ColumnDefinition Width="72" />
                                    <ColumnDefinition Width="64" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="120" />
                                </controls:Grid.ColumnDefinitions>
                                <controls:TextBlock FontWeight="SemiBold" Text="Time" />
                                <controls:TextBlock Grid.Column="1" FontWeight="SemiBold" Text="Provider" />
                                <controls:TextBlock Grid.Column="2" FontWeight="SemiBold" Text="Event" />
                                <controls:TextBlock Grid.Column="3" FontWeight="SemiBold" Text="ID" />
                                <controls:TextBlock Grid.Column="4" FontWeight="SemiBold" Text="Version" />
                                <controls:TextBlock Grid.Column="5" FontWeight="SemiBold" Text="Opcode" />
                                <controls:TextBlock Grid.Column="6" FontWeight="SemiBold" Text="Level" />
                                <controls:TextBlock Grid.Column="7" FontWeight="SemiBold" Text="PID" />
                                <controls:TextBlock Grid.Column="8" FontWeight="SemiBold" Text="Process" />
                                <controls:TextBlock Grid.Column="9" FontWeight="SemiBold" Text="Parameters" />
                            </controls:Grid>
                        </controls:ListView.Header>
                        <controls:ListView.ItemTemplate>
                            <DataTemplate>
                                <controls:Expander
                                    HorizontalContentAlignment="Stretch"
                                    HorizontalAlignment="Stretch">
                                    <controls:Expander.Header>
                                        <controls:Grid
                                            MinHeight="36"
                                            Padding="33,6,12,6"
                                            ColumnSpacing="12"
                                            HorizontalAlignment="Stretch">
                                            <controls:Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="420" />
                                                <ColumnDefinition Width="420" />
                                                <ColumnDefinition Width="64" />
                                                <ColumnDefinition Width="72" />
                                                <ColumnDefinition Width="72" />
                                                <ColumnDefinition Width="64" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="120" />
                                            </controls:Grid.ColumnDefinitions>
                                            <controls:TextBlock IsTextSelectionEnabled="True" Text="{Binding Time}" />
                                            <controls:TextBlock Grid.Column="1" IsTextSelectionEnabled="True" Text="{Binding Provider}" TextTrimming="CharacterEllipsis" />
                                            <controls:TextBlock Grid.Column="2" FontWeight="SemiBold" IsTextSelectionEnabled="True" Text="{Binding Event}" TextTrimming="CharacterEllipsis" />
                                            <controls:TextBlock Grid.Column="3" IsTextSelectionEnabled="True" Text="{Binding Id}" />
                                            <controls:TextBlock Grid.Column="4" IsTextSelectionEnabled="True" Text="{Binding Version}" />
                                            <controls:TextBlock Grid.Column="5" IsTextSelectionEnabled="True" Text="{Binding Opcode}" />
                                            <controls:TextBlock Grid.Column="6" IsTextSelectionEnabled="True" Text="{Binding Level}" />
                                            <controls:TextBlock Grid.Column="7" IsTextSelectionEnabled="True" Text="{Binding ProcessId}" />
                                            <controls:TextBlock Grid.Column="8" IsTextSelectionEnabled="True" Text="{Binding ProcessName}" TextTrimming="CharacterEllipsis" />
                                            <controls:TextBlock Grid.Column="9" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding ParameterSummary}" />
                                        </controls:Grid>
                                    </controls:Expander.Header>

                                    <controls:Grid Padding="48,0,12,12" RowSpacing="6">
                                        <controls:Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </controls:Grid.RowDefinitions>
                                        <controls:Grid Padding="0,6,0,4" ColumnSpacing="12">
                                            <controls:Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="260" />
                                                <ColumnDefinition Width="*" />
                                            </controls:Grid.ColumnDefinitions>
                                            <controls:TextBlock FontWeight="SemiBold" Text="Name" />
                                            <controls:TextBlock Grid.Column="1" FontWeight="SemiBold" Text="Value" />
                                        </controls:Grid>
                                        <controls:ItemsControl Grid.Row="1" ItemsSource="{Binding Parameters}">
                                            <controls:ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <controls:Grid Padding="0,3,0,3" ColumnSpacing="12">
                                                        <controls:Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="260" />
                                                            <ColumnDefinition Width="*" />
                                                        </controls:Grid.ColumnDefinitions>
                                                        <controls:TextBlock IsTextSelectionEnabled="True" Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                                        <controls:TextBlock Grid.Column="1" IsTextSelectionEnabled="True" Text="{Binding Value}" TextTrimming="CharacterEllipsis" />
                                                    </controls:Grid>
                                                </DataTemplate>
                                            </controls:ItemsControl.ItemTemplate>
                                        </controls:ItemsControl>
                                    </controls:Grid>
                                </controls:Expander>
                            </DataTemplate>
                        </controls:ListView.ItemTemplate>
                    </controls:ListView>
                </controls:Border>
            </controls:Grid>

            <controls:Grid
                x:Name="SavedSessionsView"
                RowSpacing="12"
                Visibility="Collapsed">
                <controls:Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </controls:Grid.RowDefinitions>

                <controls:StackPanel Spacing="4">
                    <controls:TextBlock
                        FontSize="22"
                        FontWeight="SemiBold"
                        Text="Saved Sessions" />
                    <controls:TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{Binding DatabasePathText}"
                        TextTrimming="CharacterEllipsis" />
                    <controls:TextBlock
                        Text="{Binding StatusMessage}"
                        TextWrapping="Wrap" />
                </controls:StackPanel>

                <controls:StackPanel
                    Grid.Row="1"
                    Orientation="Horizontal"
                    Spacing="8">
                    <controls:Button
                        Click="CreateSavedSessionsDatabaseButton_Click"
                        Content="Create database" />
                    <controls:Button
                        Click="OpenSavedSessionsDatabaseButton_Click"
                        Content="Open database" />
                    <controls:Button
                        Click="SaveCurrentSessionButton_Click"
                        Content="Save current session"
                        IsEnabled="{Binding CanSaveCurrentSession}" />
                    <controls:Button
                        Click="LoadSavedSessionButton_Click"
                        Content="Load"
                        IsEnabled="{Binding CanLoadSelectedSession}" />
                    <controls:Button
                        Click="DeleteSavedSessionButton_Click"
                        Content="Delete"
                        IsEnabled="{Binding CanDeleteSelectedSession}" />
                </controls:StackPanel>

                <controls:Grid
                    Grid.Row="2"
                    Padding="12,8"
                    ColumnSpacing="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <controls:Grid.ColumnDefinitions>
                        <ColumnDefinition Width="240" />
                        <ColumnDefinition Width="360" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="160" />
                    </controls:Grid.ColumnDefinitions>
                    <controls:TextBlock FontWeight="SemiBold" Text="Name" />
                    <controls:TextBlock Grid.Column="1" FontWeight="SemiBold" Text="Provider" />
                    <controls:TextBlock Grid.Column="2" FontWeight="SemiBold" Text="Event filter" />
                    <controls:TextBlock Grid.Column="3" FontWeight="SemiBold" Text="Updated" />
                </controls:Grid>

                <controls:ListView
                    Grid.Row="3"
                    ItemsSource="{Binding Templates}"
                    SelectedItem="{Binding SelectedTemplate, Mode=TwoWay}"
                    SelectionMode="Single">
                    <controls:ListView.ItemContainerStyle>
                        <Style TargetType="controls:ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </controls:ListView.ItemContainerStyle>
                    <controls:ListView.ItemTemplate>
                        <DataTemplate>
                            <controls:Grid Padding="4,6" ColumnSpacing="12">
                                <controls:Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="240" />
                                    <ColumnDefinition Width="360" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="160" />
                                </controls:Grid.ColumnDefinitions>
                                <controls:TextBlock
                                    FontWeight="SemiBold"
                                    Text="{Binding Name}"
                                    TextTrimming="CharacterEllipsis" />
                                <controls:TextBlock
                                    Grid.Column="1"
                                    Text="{Binding Provider}"
                                    TextTrimming="CharacterEllipsis" />
                                <controls:TextBlock
                                    Grid.Column="2"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{Binding FilterSummary}"
                                    TextTrimming="CharacterEllipsis" />
                                <controls:TextBlock
                                    Grid.Column="3"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{Binding UpdatedAt}" />
                            </controls:Grid>
                        </DataTemplate>
                    </controls:ListView.ItemTemplate>
                </controls:ListView>
            </controls:Grid>

            <controls:Grid
                x:Name="HelpView"
                RowSpacing="12"
                Visibility="Collapsed">
                <controls:Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </controls:Grid.RowDefinitions>

                <controls:StackPanel Spacing="4">
                    <controls:TextBlock
                        FontSize="22"
                        FontWeight="SemiBold"
                        Text="Help" />
                    <controls:TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="Filtering, recording, and provider privilege notes."
                        TextWrapping="Wrap" />
                </controls:StackPanel>

                <controls:ScrollViewer
                    Grid.Row="1"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
                    <controls:StackPanel
                        MaxWidth="980"
                        HorizontalAlignment="Left"
                        Spacing="16">
                        <controls:Border
                            Padding="16"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="4">
                            <controls:StackPanel Spacing="8">
                                <controls:TextBlock
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Text="Event filtering" />
                                <controls:TextBlock
                                    Text="Basic mode matches text case-insensitively across the relevant fields. When the text contains * or ?, EtwSuite treats it as a wildcard pattern."
                                    TextWrapping="Wrap" />
                                <controls:TextBlock
                                    Text="SQL mode accepts a SQL-like boolean expression for captured events. It is an in-process expression parser, not database SQL: it does not query a database, call functions, or allow arbitrary member access."
                                    TextWrapping="Wrap" />
                            </controls:StackPanel>
                        </controls:Border>

                        <controls:Border
                            Padding="16"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="4">
                            <controls:StackPanel Spacing="8">
                                <controls:TextBlock
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Text="SQL syntax" />
                                <controls:TextBlock
                                    IsTextSelectionEnabled="True"
                                    Text="The filter accepts an optional leading WHERE followed by a boolean expression."
                                    TextWrapping="Wrap" />
                                <controls:Grid
                                    ColumnSpacing="12"
                                    RowSpacing="4">
                                    <controls:Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="3*" />
                                    </controls:Grid.ColumnDefinitions>
                                    <controls:Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </controls:Grid.RowDefinitions>
                                    <controls:TextBlock FontWeight="SemiBold" Text="Operator" />
                                    <controls:TextBlock Grid.Column="1" FontWeight="SemiBold" Text="Usage" />
                                    <controls:TextBlock Grid.Column="2" FontWeight="SemiBold" Text="Example" />
                                    <controls:TextBlock Grid.Row="1" FontFamily="Consolas" IsTextSelectionEnabled="True" Text="AND" />
                                    <controls:TextBlock Grid.Row="1" Grid.Column="1" Text="Require both conditions." TextWrapping="Wrap" />
                                    <controls:TextBlock Grid.Row="1" Grid.Column="2" FontFamily="Consolas" IsTextSelectionEnabled="True" Text="event_id = 1 AND level &lt;= 4" TextWrapping="Wrap" />
                                    <controls:TextBlock Grid.Row="2" FontFamily="Consolas" IsTextSelectionEnabled="True" Text="OR" />
                                    <controls:TextBlock Grid.Row="2" Grid.Column="1" Text="Match either condition." TextWrapping="Wrap" />
                                    <controls:TextBlock Grid.Row="2" Grid.Column="2" FontFamily="Consolas" IsTextSelectionEnabled="True" Text="event_id = 1 OR event_id = 2" TextWrapping="Wrap" />
                                    <controls:TextBlock Grid.Row="3" FontFamily="Consolas" IsTextSelectionEnabled="True" Text="NOT" />
                                    <controls:TextBlock Grid.Row="3" Grid.Column="1" Text="Negate a condition." TextWrapping="Wrap" />
                                    <controls:TextBlock Grid.Row="3" Grid.Column="2" FontFamily="Consolas" IsTextSelectionEnabled="True" Text="NOT process_name LIKE 'powershell%'" TextWrapping="Wrap" />
                                    <controls:TextBlock Grid.Row="4" FontFamily="Consolas" IsTextSelectionEnabled="True" Text="( )" />
                                    <controls:TextBlock Grid.Row="4" Grid.Column="1" Text="Group conditions." TextWrapping="Wrap" />
                                    <controls:TextBlock Grid.Row="4" Grid.Column="2" FontFamily="Consolas" IsTextSelectionEnabled="True" Text="(event_id = 1 OR event_id = 2) AND level &lt;= 4" TextWrapping="Wrap" />
                                    <controls:TextBlock Grid.Row="5" FontFamily="Consolas" IsTextSelectionEnabled="True" Text="=" />
                                    <controls:TextBlock Grid.Row="5" Grid.Column="1" Text="Equal to." TextWrapping="Wrap" />
                                    <controls:TextBlock Grid.Row="5" Grid.Column="2" FontFamily="Consolas" IsTextSelectionEnabled="True" Text="provider = 'Microsoft-Windows-Kernel-Process'" TextWrapping="Wrap" />
                                    <controls:TextBlock Grid.Row="6" FontFamily="Consolas" IsTextSelectionEnabled="True" Text="!=" />
                                    <controls:TextBlock Grid.Row="6" Grid.Column="1" Text="Not equal to." TextWrapping="Wrap" />
                                    <controls:TextBlock Grid.Row="6" Grid.Column="2" FontFamily="Consolas" IsTextSelectionEnabled="True" Text="process_name != 'svchost.exe'" TextWrapping="Wrap" />
                                    <controls:TextBlock Grid.Row="7" FontFamily="Consolas" IsTextSelectionEnabled="True" Text="&lt;&gt;" />
                                    <controls:TextBlock Grid.Row="7" Grid.Column="1" Text="Not equal to." TextWrapping="Wrap" />
                                    <controls:TextBlock Grid.Row="7" Grid.Column="2" FontFamily="Consolas" IsTextSelectionEnabled="True" Text="event_name &lt;&gt; 'Verbose'" TextWrapping="Wrap" />
                                    <controls:TextBlock Grid.Row="8" FontFamily="Consolas" IsTextSelectionEnabled="True" Text="&lt;" />
                                    <controls:TextBlock Grid.Row="8" Grid.Column="1" Text="Less than." TextWrapping="Wrap" />
                                    <controls:TextBlock Grid.Row="8" Grid.Column="2" FontFamily="Consolas" IsTextSelectionEnabled="True" Text="level &lt; 5" TextWrapping="Wrap" />
                                    <controls:TextBlock Grid.Row="9" FontFamily="Consolas" IsTextSelectionEnabled="True" Text="&lt;=" />
                                    <controls:TextBlock Grid.Row="9" Grid.Column="1" Text="Less than or equal to." TextWrapping="Wrap" />
                                    <controls:TextBlock Grid.Row="9" Grid.Column="2" FontFamily="Consolas" IsTextSelectionEnabled="True" Text="pid &lt;= 4242" TextWrapping="Wrap" />
                                    <controls:TextBlock Grid.Row="10" FontFamily="Consolas" IsTextSelectionEnabled="True" Text="&gt;" />
                                    <controls:TextBlock Grid.Row="10" Grid.Column="1" Text="Greater than." TextWrapping="Wrap" />
                                    <controls:TextBlock Grid.Row="10" Grid.Column="2" FontFamily="Consolas" IsTextSelectionEnabled="True" Text="thread_id &gt; 1000" TextWrapping="Wrap" />
                                    <controls:TextBlock Grid.Row="11" FontFamily="Consolas" IsTextSelectionEnabled="True" Text="&gt;=" />
                                    <controls:TextBlock Grid.Row="11" Grid.Column="1" Text="Greater than or equal to." TextWrapping="Wrap" />
                                    <controls:TextBlock Grid.Row="11" Grid.Column="2" FontFamily="Consolas" IsTextSelectionEnabled="True" Text="event_id &gt;= 10" TextWrapping="Wrap" />
                                    <controls:TextBlock Grid.Row="12" FontFamily="Consolas" IsTextSelectionEnabled="True" Text="LIKE" />
                                    <controls:TextBlock Grid.Row="12" Grid.Column="1" Text="Match a wildcard pattern." TextWrapping="Wrap" />
                                    <controls:TextBlock Grid.Row="12" Grid.Column="2" FontFamily="Consolas" IsTextSelectionEnabled="True" Text="payload.ImageName LIKE '*cmd.exe'" TextWrapping="Wrap" />
                                </controls:Grid>
                                <controls:TextBlock
                                    IsTextSelectionEnabled="True"
                                    Text="String values use single quotes. Escape a single quote by doubling it, for example: event_name = 'User''s Event'."
                                    TextWrapping="Wrap" />
                                <controls:TextBlock
                                    IsTextSelectionEnabled="True"
                                    Text="LIKE supports SQL wildcards and EtwSuite wildcards: % or * matches zero or more characters; _ or ? matches one character. Matching is case-insensitive."
                                    TextWrapping="Wrap" />
                                <controls:TextBlock
                                    FontFamily="Consolas"
                                    IsTextSelectionEnabled="True"
                                    Text="WHERE provider LIKE 'Microsoft-Windows-*' AND event_id = 1"
                                    TextWrapping="Wrap" />
                            </controls:StackPanel>
                        </controls:Border>

                        <controls:Border
                            Padding="16"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="4">
                            <controls:StackPanel Spacing="8">
                                <controls:TextBlock
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Text="Fields / variables" />
                                <controls:TextBlock
                                    Text="SQL field names identify event properties. Numeric comparisons are supported for numeric fields such as event_id, level, pid, and thread_id."
                                    TextWrapping="Wrap" />
                                <controls:Grid
                                    ColumnSpacing="12"
                                    RowSpacing="4">
                                    <controls:Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220" />
                                        <ColumnDefinition Width="*" />
                                    </controls:Grid.ColumnDefinitions>
                                    <controls:Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </controls:Grid.RowDefinitions>
                                    <controls:TextBlock FontWeight="SemiBold" Text="Field" />
                                    <controls:TextBlock Grid.Column="1" FontWeight="SemiBold" Text="Meaning" />
                                    <controls:TextBlock Grid.Row="1" FontFamily="Consolas" IsTextSelectionEnabled="True" Text="provider" />
                                    <controls:TextBlock Grid.Row="1" Grid.Column="1" Text="Provider display name." TextWrapping="Wrap" />
                                    <controls:TextBlock Grid.Row="2" FontFamily="Consolas" IsTextSelectionEnabled="True" Text="provider_id" />
                                    <controls:TextBlock Grid.Row="2" Grid.Column="1" Text="Provider GUID." TextWrapping="Wrap" />
                                    <controls:TextBlock Grid.Row="3" FontFamily="Consolas" IsTextSelectionEnabled="True" Text="event, event_name" />
                                    <controls:TextBlock Grid.Row="3" Grid.Column="1" Text="Decoded event name when metadata is available." TextWrapping="Wrap" />
                                    <controls:TextBlock Grid.Row="4" FontFamily="Consolas" IsTextSelectionEnabled="True" Text="id, event_id" />
                                    <controls:TextBlock Grid.Row="4" Grid.Column="1" Text="Numeric event identifier." TextWrapping="Wrap" />
                                    <controls:TextBlock Grid.Row="5" FontFamily="Consolas" IsTextSelectionEnabled="True" Text="version" />
                                    <controls:TextBlock Grid.Row="5" Grid.Column="1" Text="Event version." TextWrapping="Wrap" />
                                    <controls:TextBlock Grid.Row="6" FontFamily="Consolas" IsTextSelectionEnabled="True" Text="opcode" />
                                    <controls:TextBlock Grid.Row="6" Grid.Column="1" Text="Event opcode value or decoded name." TextWrapping="Wrap" />
                                    <controls:TextBlock Grid.Row="7" FontFamily="Consolas" IsTextSelectionEnabled="True" Text="level" />
                                    <controls:TextBlock Grid.Row="7" Grid.Column="1" Text="Event severity or verbosity level." TextWrapping="Wrap" />
                                    <controls:TextBlock Grid.Row="8" FontFamily="Consolas" IsTextSelectionEnabled="True" Text="pid, process_id" />
                                    <controls:TextBlock Grid.Row="8" Grid.Column="1" Text="Process ID associated with the event." TextWrapping="Wrap" />
                                    <controls:TextBlock Grid.Row="9" FontFamily="Consolas" IsTextSelectionEnabled="True" Text="process, process_name" />
                                    <controls:TextBlock Grid.Row="9" Grid.Column="1" Text="Process name associated with the event, when resolved." TextWrapping="Wrap" />
                                    <controls:TextBlock Grid.Row="10" FontFamily="Consolas" IsTextSelectionEnabled="True" Text="tid, thread_id" />
                                    <controls:TextBlock Grid.Row="10" Grid.Column="1" Text="Thread ID associated with the event." TextWrapping="Wrap" />
                                </controls:Grid>
                                <controls:Grid
                                    ColumnSpacing="12"
                                    RowSpacing="4">
                                    <controls:Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220" />
                                        <ColumnDefinition Width="*" />
                                    </controls:Grid.ColumnDefinitions>
                                    <controls:Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </controls:Grid.RowDefinitions>
                                    <controls:TextBlock Grid.Row="0" FontFamily="Consolas" IsTextSelectionEnabled="True" Text="payload" />
                                    <controls:TextBlock Grid.Row="0" Grid.Column="1" Text="Combined payload names, types, and values." TextWrapping="Wrap" />
                                    <controls:TextBlock Grid.Row="1" FontFamily="Consolas" IsTextSelectionEnabled="True" Text="payload.&lt;fieldName&gt;" />
                                    <controls:TextBlock Grid.Row="1" Grid.Column="1" Text="One named payload field, for example payload.ImageName." TextWrapping="Wrap" />
                                </controls:Grid>
                            </controls:StackPanel>
                        </controls:Border>

                        <controls:Border
                            Padding="16"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="4">
                            <controls:StackPanel Spacing="8">
                                <controls:TextBlock
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Text="Recording types" />
                                <controls:TextBlock
                                    Text="Live consumption starts an ETW session for the selected provider and shows decoded events as they arrive."
                                    TextWrapping="Wrap" />
                                <controls:TextBlock
                                    Text="JSON and CSV export write the currently captured event rows from EtwSuite."
                                    TextWrapping="Wrap" />
                                <controls:TextBlock
                                    Text="ETL recording writes a native ETW trace file while consuming a provider. EtwSuite does not synthesize ETL files from already decoded rows."
                                    TextWrapping="Wrap" />
                                <controls:TextBlock
                                    Text="Open Recording can load .etl, .json, and .csv files. ETL payload decoding is best-effort because provider metadata can be incomplete or unavailable."
                                    TextWrapping="Wrap" />
                            </controls:StackPanel>
                        </controls:Border>

                        <controls:Border
                            Padding="16"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="4">
                            <controls:StackPanel Spacing="8">
                                <controls:TextBlock
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Text="How to record ETL" />
                                <controls:Grid
                                    ColumnSpacing="12"
                                    RowSpacing="6">
                                    <controls:Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32" />
                                        <ColumnDefinition Width="*" />
                                    </controls:Grid.ColumnDefinitions>
                                    <controls:Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </controls:Grid.RowDefinitions>
                                    <controls:TextBlock FontWeight="SemiBold" Text="1." />
                                    <controls:TextBlock Grid.Column="1" Text="Open the Consume Provider tab." TextWrapping="Wrap" />
                                    <controls:TextBlock Grid.Row="1" FontWeight="SemiBold" Text="2." />
                                    <controls:TextBlock Grid.Row="1" Grid.Column="1" Text="Select the provider to consume." TextWrapping="Wrap" />
                                    <controls:TextBlock Grid.Row="2" FontWeight="SemiBold" Text="3." />
                                    <controls:TextBlock Grid.Row="2" Grid.Column="1" Text="Enable Record ETL." TextWrapping="Wrap" />
                                    <controls:TextBlock Grid.Row="3" FontWeight="SemiBold" Text="4." />
                                    <controls:TextBlock Grid.Row="3" Grid.Column="1" Text="Start consuming and choose the .etl destination path when prompted." TextWrapping="Wrap" />
                                    <controls:TextBlock Grid.Row="4" FontWeight="SemiBold" Text="5." />
                                    <controls:TextBlock Grid.Row="4" Grid.Column="1" Text="Stop consuming to close and flush the trace file." TextWrapping="Wrap" />
                                    <controls:TextBlock Grid.Row="5" FontWeight="SemiBold" Text="6." />
                                    <controls:TextBlock Grid.Row="5" Grid.Column="1" Text="Use Open recorded, or open the .etl file from the Open Recording tab." TextWrapping="Wrap" />
                                </controls:Grid>
                            </controls:StackPanel>
                        </controls:Border>

                        <controls:Border
                            Padding="16"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="4">
                            <controls:StackPanel Spacing="8">
                                <controls:TextBlock
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Text="Privileges" />
                                <controls:TextBlock
                                    Text="Some ETW operations require administrator privileges or tracing/logging group membership. EtwSuite does not automatically elevate."
                                    TextWrapping="Wrap" />
                                <controls:TextBlock
                                    Text="Some providers, such as Microsoft-Windows-Kernel-Process, can require administrative privileges for recording."
                                    TextWrapping="Wrap" />
                                <controls:TextBlock
                                    Text="Microsoft-Windows-Threat-Intelligence live consumption requires an allowed Protected Process Light (PPL) signer. Administrator elevation alone is not enough."
                                    TextWrapping="Wrap" />
                            </controls:StackPanel>
                        </controls:Border>
                    </controls:StackPanel>
                </controls:ScrollViewer>
            </controls:Grid>
        </controls:Grid>
    </controls:NavigationView>
</Window>
